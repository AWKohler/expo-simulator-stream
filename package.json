{
  "name": "expo-stream",
  "version": "0.2.0",
  "private": true,
  "description": "iOS Simulator streaming platform — Controller + Host Agent + Web",
  "scripts": {
    "build": "pnpm -r --parallel run build",
    "dev:controller": "pnpm --filter @sim/controller dev",
    "dev:host": "pnpm --filter @sim/host-agent dev",
    "dev:web": "pnpm --filter @sim/web dev",
    "dev": "pnpm --parallel --filter @sim/controller --filter @sim/host-agent --filter @sim/web dev",
    "typecheck": "pnpm -r --parallel run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@8.15.5"
}
